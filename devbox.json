{
  "$schema": "https://raw.githubusercontent.com/jetify-com/devbox/latest/.schema/devbox.schema.json",
  "packages": [
    "mise@latest",
    "git@latest",
    "gcc@latest",
    "gnumake@latest",
    "age@latest",
    "sops@latest",
    "earthly@latest"
  ],
  "shell": {
    "init_hook": [
      "export MISE_DATA_DIR=$PWD/.devbox/mise_data",
      "export MISE_CACHE_DIR=$PWD/.devbox/mise_cache",
      "export MISE_INSTALL_PATH=$PWD/.devbox/mise_installs",
      "export MISE_SHIMS_DIR=$PWD/.devbox/mise_shims",
      "eval \"$(mise activate bash)\"",
      "export PATH=\"$MISE_SHIMS_DIR:$PATH\"",
      "export MIX_BUILD_PATH=$PWD/.devbox/build",
      "mise trust",
      "mise install",
      "mix local.hex --force --quiet 2>/dev/null || true",
      "mix local.rebar --force --quiet 2>/dev/null || true",
      "mix deps.get 2>/dev/null || true",
      "mix deps.compile 2>/dev/null || true",
      "MIX_ENV=test mix deps.compile 2>/dev/null || true"
    ],
    "persistent_dirs": [
      ".devbox/mise_data",
      ".devbox/mise_cache",
      ".devbox/mise_installs"
    ]
  }
}
